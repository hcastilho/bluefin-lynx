#!/bin/bash
# Switch Waydroid to portrait orientation (1200×1920).
# Run after rotating the screen to portrait mode.
set -euo pipefail

waydroid prop set persist.waydroid.width 960
waydroid prop set persist.waydroid.height 1504
waydroid session stop
sudo waydroid container stop

echo "Waydroid is now in portrait mode (960×1504)."
