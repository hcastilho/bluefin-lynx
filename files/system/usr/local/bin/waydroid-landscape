#!/bin/bash
# Switch Waydroid to landscape orientation (1920×1200).
# Run after rotating the screen to landscape mode.
set -euo pipefail

waydroid prop set persist.waydroid.width 1536
waydroid prop set persist.waydroid.height 928
waydroid session stop
sudo waydroid container stop

echo "Waydroid is now in landscape mode (1536×928)."
